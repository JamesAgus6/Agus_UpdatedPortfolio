rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow reading comments by everyone
    match /comments/{docId} {
      allow read: if true;
      // Allow creating comments by everyone - validate required fields
      allow create: if 
        request.resource.data.name != null && 
        request.resource.data.name != '' &&
        request.resource.data.message != null && 
        request.resource.data.message != '' &&
        request.resource.data.timestamp != null;
      // Prevent updates and deletes
      allow update: if false;
      allow delete: if false;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}